{
  "name": "cb-mpc",
  "version": "0.1.10",
  "type": "module",
  "description": "cb-mpc cryptographic MPC library compiled to WebAssembly",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "cbmpc.js",
    "cbmpc.wasm",
    "prebuilds/",
    "examples/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cbmpc.js": "./cbmpc.js",
    "./cbmpc.wasm": "./cbmpc.wasm"
  },
  "scripts": {
    "build:types": "tsc",
    "build": "tsc",
    "demo:curve-ops": "bun run examples/curve-ops.ts",
    "demo:ecdsa-2pc": "bun run examples/ecdsa-2pc.ts",
    "demo:ecdsa-mpc": "bun run examples/ecdsa-mpc.ts",
    "demo:eddsa-2pc": "bun run examples/eddsa-2pc.ts",
    "demo:eddsa-mpc": "bun run examples/eddsa-mpc.ts",
    "demo:agree-random": "bun run examples/agree-random.ts",
    "demo:bun-ffi": "bun run examples/bun-ffi-demo.ts",
    "demo:key-serialization": "bun run examples/key-serialization.ts"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nguyenkha/cb-mpc"
  },
  "keywords": [
    "mpc",
    "cryptography",
    "ecdsa",
    "eddsa",
    "wasm",
    "webassembly",
    "threshold-signatures"
  ],
  "dependencies": {
    "debug": "^4.4.3"
  }
}
