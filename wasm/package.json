{
  "name": "@aspect-build/cb-mpc-wasm",
  "version": "0.1.0",
  "description": "cb-mpc cryptographic MPC library compiled to WebAssembly",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "cbmpc.js",
    "cbmpc.wasm"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cbmpc.js": "./cbmpc.js",
    "./cbmpc.wasm": "./cbmpc.wasm"
  },
  "scripts": {
    "build:types": "tsc",
    "build": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/coinbase/cb-mpc"
  },
  "keywords": [
    "mpc",
    "cryptography",
    "ecdsa",
    "eddsa",
    "wasm",
    "webassembly",
    "threshold-signatures"
  ]
}
